{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "endOfLine": "lf",
  "plugins": ["@prettier/plugin-php"],
  "overrides": [
    {
      "files": "**/*.php",
      "options": {
        "parser": "php",
        "phpVersion": "8.2",
        "tabWidth": 4,
        "singleQuote": true
      }
    }
  ]
}
