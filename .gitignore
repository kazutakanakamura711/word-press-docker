# 環境変数
.env

# WP本体
src/wp-admin/
src/wp-includes/
src/wp-*.php
src/index.php
src/license.txt
src/readme.html
src/xmlrpc.php
src/.htaccess

# wp-content直下
src/wp-content/index.php
src/wp-content/languages/
src/wp-content/uploads/
src/wp-content/plugins/
src/wp-content/cache/
src/wp-content/upgrade/

# ローカル開発用 mu-plugins（本番デプロイ不要）
src/wp-content/mu-plugins/

# デフォルトテーマ
src/wp-content/themes/twentytwenty*/
src/wp-content/themes/index.php

# 自作テーマは管理する（除外しない）
!src/wp-content/themes/my-theme/
!src/wp-content/themes/medical-theme/

# node_modules（全テーマ共通）
src/wp-content/themes/*/node_modules/

# Viteビルド後のアセット（全テーマ共通）
src/wp-content/themes/*/assets/

# ビルド状態キャッシュ
src/wp-content/themes/*/.ftp-deploy-sync-state.json
